events {}

http {
    gzip on;

    server {
        listen 80;

        location /health {
            return 200 "OK";
        }

        location /providers/ {
            root /data;
            add_header Cache-Control "public, max-age=31536000, immutable";
            try_files $uri @fallback;
        }

        location @fallback {
            proxy_pass https://registry.comcloud.xyz/;
        }

        location /tf-org/ {
            proxy_pass https://tf.org.ru/;
        }

        location /mcs/ {
            proxy_pass https://terraform-mirror.mcs.mail.ru/;
        }
    }
}