version: "3.9"

services:
  mirror:
    build: .
    environment:
      - S3_BUCKET={{ bucket }}

  nginx:
    image: nginx
    volumes:
      - ./nginx.conf:/etc/nginx/nginx.conf
      - mirror_data:/data
    ports:
      - "80:80"
      - "443:443"

  prometheus:
    image: prom/prometheus
    volumes:
      - ./prometheus.yml:/etc/prometheus/prometheus.yml
    ports:
      - "9090:9090"

  grafana:
    image: grafana/grafana
    ports:
      - "3000:3000"

volumes:
  mirror_data: