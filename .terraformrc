#############################################################
# Terraform CLI Configuration (Production)
# Optimized for CI/CD, DevOps environments
#############################################################

#############################################################
# Provider plugin cache
# Dramatically speeds up terraform init
#############################################################

plugin_cache_dir = "$HOME/.terraform.d/plugin-cache"

disable_checkpoint = true
disable_checkpoint_signature = true

#############################################################
# Provider installation strategy
#############################################################

provider_installation {

  ###########################################################
  # 1. Local filesystem mirror (offline providers)
  # Used first if provider exists locally
  ###########################################################

  filesystem_mirror {
    path    = "$HOME/.terraform.d/providers"
    include = ["*/*"]
  }

  ###########################################################
  # 2. Yandex Terraform mirror (fast CDN)
  ###########################################################

  network_mirror {
    url     = "https://terraform-mirror.yandexcloud.net/"
    include = ["registry.terraform.io/*/*"]
  }

  ###########################################################
  # 3. Community Terraform mirror
  ###########################################################

  network_mirror {
    url     = "https://library.tf/"
    include = ["registry.terraform.io/*/*"]
  }

  ###########################################################
  # 4. Hashicorp official registry 
  ###########################################################

  direct {
    exclude = ["registry.terraform.io/*/*"]
  }

}